<Project>

  <!-- Imported late into the consumer's build. Copies the current target's Valve
       native binary next to the built assemblies, where SteamNative's resolver
       looks. Copies ONLY the target's binary so a macOS .app isn't burdened with
       foreign, unsigned libraries at notarization time. -->

  <PropertyGroup>
    <_BoilerPkgRoot>$(MSBuildThisFileDirectory)..</_BoilerPkgRoot>
  </PropertyGroup>

  <ItemGroup Condition="$(RuntimeIdentifier.StartsWith('win')) OR ('$(RuntimeIdentifier)' == '' AND $([MSBuild]::IsOSPlatform('Windows')))">
    <None Include="$(_BoilerPkgRoot)\steam\native\win-x64\steam_api64.dll" Link="steam_api64.dll" CopyToOutputDirectory="PreserveNewest" Visible="false" />
  </ItemGroup>

  <ItemGroup Condition="$(RuntimeIdentifier.StartsWith('osx')) OR ('$(RuntimeIdentifier)' == '' AND $([MSBuild]::IsOSPlatform('OSX')))">
    <None Include="$(_BoilerPkgRoot)\steam\native\osx\libsteam_api.dylib" Link="libsteam_api.dylib" CopyToOutputDirectory="PreserveNewest" Visible="false" />
  </ItemGroup>

  <ItemGroup Condition="$(RuntimeIdentifier.StartsWith('linux')) OR ('$(RuntimeIdentifier)' == '' AND $([MSBuild]::IsOSPlatform('Linux')))">
    <None Include="$(_BoilerPkgRoot)\steam\native\linux-x64\libsteam_api.so" Link="libsteam_api.so" CopyToOutputDirectory="PreserveNewest" Visible="false" />
  </ItemGroup>

</Project>
