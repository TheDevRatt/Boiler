<Project>

  <!-- Imported early into the consumer's build. Does two things:
       1. references the Facepunch managed assembly matching the target platform
          (Facepunch ships a distinct assembly per platform), and
       2. injects a module initializer into the consumer's own assembly so the
          native resolver is installed automatically at startup — no code needed.
       RuntimeIdentifier (set by `godot export` / `dotnet publish -r`) wins;
       otherwise the host OS decides. -->

  <PropertyGroup>
    <_BoilerPkgRoot>$(MSBuildThisFileDirectory)..</_BoilerPkgRoot>
    <_BoilerTargetsWindows Condition="$(RuntimeIdentifier.StartsWith('win')) OR ('$(RuntimeIdentifier)' == '' AND $([MSBuild]::IsOSPlatform('Windows')))">true</_BoilerTargetsWindows>
  </PropertyGroup>

  <ItemGroup Condition="'$(_BoilerTargetsWindows)' == 'true'">
    <Reference Include="Facepunch.Steamworks.Win64">
      <HintPath>$(_BoilerPkgRoot)\steam\managed\Facepunch.Steamworks.Win64.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup Condition="'$(_BoilerTargetsWindows)' != 'true'">
    <Reference Include="Facepunch.Steamworks.Posix">
      <HintPath>$(_BoilerPkgRoot)\steam\managed\Facepunch.Steamworks.Posix.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

  <!-- Compiles a [ModuleInitializer] into the consumer assembly; it runs at
       startup (before any game code) and calls SteamNative.Register(). -->
  <ItemGroup>
    <Compile Include="$(MSBuildThisFileDirectory)BoilerAutoInit.cs" />
  </ItemGroup>

</Project>
